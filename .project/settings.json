{
  "$schema": "../schemas/settings.schema.json",
  "sources": {
    "engine": {
      "tag": "stable"
    },
    "engine-res": {
      "tag": "stable"
    },
    "official-res": {
      "tag": "stable"
    }
  },
  "build": {
    "generate_fs_path": true,
    "output_dir": "../dist",
    "asset_dirs": [
      "../assets",
      "../scripts"
    ],
    "asset_ignores": [
      "assets/Characters/player_animations/idle/stand_[0-9][0-9].png",
      "assets/Characters/player_animations/move/move_[0-9][0-9].png",
      "assets/Characters/player_animations/block/猫咪序列帧_[0-9][0-9].png"
    ]
  },
  "@runtime": {
    "multiplayer": {
      "enabled": false,
      "max_players": 4,
      "background_match": false,
      "match_info": {
        "desc_name": "free_match",
        "immediately_start": false,
        "match_timeout": 0,
        "player_number": 1
      },
      "persistent_world": {
        "enabled": false
      }
    }
  }
}
